# =============================================================================
# Lure — Phishing Analysis Platform
# Environment Configuration Template
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# --- Threat Intelligence APIs ------------------------------------------------
# VirusTotal v3 — https://virustotal.com/gui/sign-in (Free: 4 req/min, 500/day)
VT_API_KEY=

# AbuseIPDB v2 — https://abuseipdb.com/account/api (Free: 1000 req/day)
ABUSEIPDB_KEY=

# Shodan — https://account.shodan.io (Free: 100 queries/month)
SHODAN_API_KEY=

# urlscan.io — https://urlscan.io/user/signup (Free: 1000 private scans/day)
URLSCAN_KEY=

# AlienVault OTX — https://otx.alienvault.com (Free: unlimited)
OTX_KEY=

# PhishTank — https://phishtank.org/api_register (Free: 1000 req/day)
PHISHTANK_KEY=

# Google Safe Browsing v4 — https://console.cloud.google.com (Free: 10k/day)
GSB_KEY=

# --- SOC Integrations --------------------------------------------------------
# TheHive — Self-hosted (https://github.com/TheHive-Project/TheHive)
THEHIVE_URL=http://localhost:9000
THEHIVE_KEY=

# MISP — Self-hosted (https://github.com/MISP/MISP)
MISP_URL=http://localhost
MISP_KEY=

# --- LLM Layer ---------------------------------------------------------------
# Ollama — Local only. NEVER expose to network. (https://ollama.ai)
# SECURITY: Ollama binds to 0.0.0.0 by default — set OLLAMA_HOST=127.0.0.1
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# --- Lure Behaviour ----------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Cache TTL overrides (hours) — leave blank to use defaults
# CACHE_TTL_VT=48
# CACHE_TTL_ABUSEIPDB=24
# CACHE_TTL_SHODAN=72
# CACHE_TTL_URLSCAN=24
# CACHE_TTL_WHOIS=168

# Max redirect hops to follow before stopping chain
MAX_REDIRECT_HOPS=5

# Verdict score thresholds (override defaults)
# THRESHOLD_SUSPICIOUS=3.0
# THRESHOLD_LIKELY_PHISHING=5.0
# THRESHOLD_CONFIRMED_MALICIOUS=8.0
