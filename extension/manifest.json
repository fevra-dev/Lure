{
  "manifest_version": 3,
  "name": "PhishOps Security Suite",
  "version": "1.0.0",
  "description": "Browser-native phishing defence: 49 detectors covering OAuth abuse, HTML smuggling, extension supply chain, clipboard injection, fullscreen overlay, passkey theft, QR session hijacking, virtual camera detection, TOAD screen share, brand impersonation, AiTM proxy detection, browser sync hijacking, helpdesk platform abuse, FIDO downgrade attacks, IPFS gateway phishing, LOTL trusted domain abuse, AI-generated phishing detection, EvilnoVNC WebSocket AiTM, WebSocket credential exfiltration, Service Worker persistence, blockchain-hosted phishing (EtherHiding), notification abuse, WebTransport AiTM relay, canvas credential phishing, canvas keystroke capture, canvas credential exfiltration, Speculation Rules API phishing, security tool probing meta-detection, Payment Request API phishing signal, File System Access API credential exfiltration, threat intelligence feed synchronization (PhishStats + phishnet.cc), SPA navigation phishing detection (pushState / Navigation API intercept), WebRTC synthetic track deepfake sentinel, and agentic guardrails.",

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "management",
    "webRequest",
    "webNavigation",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/allowlist_gate.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/shadow_dom_utils.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/state_parameter_abuse.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/agentintentguard.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/autofill_guard.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/clickfix_clipboard_defender.js"],
      "run_at": "document_start"
    },
    {
